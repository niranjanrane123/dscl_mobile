<ion-view >
	<!-- <ion-nav-bar class="bar-dark" align-title="center">  <ion-nav-back-button></ion-nav-back-button></ion-nav-bar> -->
	<ion-nav-bar class="bar-dark" align-title="center">
		
		<ion-nav-back-button class="button-clear">
		  <button class="icon ion-chevron-left" ng-click="myGoBack()" ng-controller="TodoCtrl"  style="background: transparent;border: none;"></button>
		  <!-- <div side="center">
			<img src="./img/doon1-3d-test_13-10-2021.png" style="margin-left: 118px;
			height: 30px;
			width: 40px;">
			</div> -->
			<img style="right: 46%;
     position: absolute;
     margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width=38px; height=35px;>
		</ion-nav-back-button>
	  </ion-nav-bar>
	<ion-content ng-controller="FaqCtrl" class="HomeBackground">
	  <!--<h3 class="heading">Frequently Asked Questions</h3>-->
	  <div class="headingDiv">
		<h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading"translate="FAQ"><img src="./img/quick-services-32x32.png" width="32" height="32" ></h3>
	  </div>
  
	  <ion-list>
		<div ng-repeat="group in groups" class="padding">
		  <ion-item class="item-stable "
					ng-click="toggleGroup(group)"
					ng-class="{active: isGroupShown(group)}" translate ="{{group.name}}">
			<i class="icon" ng-class="isGroupShown(group) ? 'ion-minus' : 'ion-plus'"></i>
			&nbsp;
		  </ion-item>
		  <ion-item class="item-accordion"
					ng-repeat="item in group.items"
					ng-show="isGroupShown(group)">
			<div translate ="{{item.subId}}"></div>
		  </ion-item>
		</div>
  
	  </ion-list>
	</ion-content>
  </ion-view>
  
  <style>
  
  
 
  
  </style>
  
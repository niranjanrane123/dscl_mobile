<ion-view>
  <!-- <ion-nav-bar class="bar-dark" align-title="center">
  <ion-nav-back-button class="button-clear">
    <button class="icon ion-chevron-left" ng-click="myGoBack()" ng-controller="TodoCtrl"  style="background: transparent;border: none;"></button>
    <img style="right: 46%;
    position: absolute;
    margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width=38px; height=35px;>
  </ion-nav-back-button>
  </ion-nav-bar> -->
  <ion-nav-buttons side="left" >
      <div class="title title-center header-item" style="font-weight: bold; color: #fff; left: 48px; right: 48px; font-size: 21px; text-align: center; top: 0px;">
          <!-- {{'ECHATTISGARH' | translate}} -->
        </div>
        <img style="right: 46%;
        position: absolute;
        margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width=38px; height=35px;>
  </ion-nav-buttons>

  <ion-content>
      <div class="headingDiv">
          <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading">{{heading}}</h3>
      </div>
          <div class="refresh-btn-container" style="z-index: 999999;">
        <div class="col col-33 float" ng-click="getCurrentStatus()">
            <div class="list list-icon text-center noMargin">
                <a class="gridnopadding">
                    <img ng-class="{'rotate': isRefreshing}" src="img/refresh.png" height="65" width="65">
                </a>
                <h5 style="font-size:13px">Refresh</h5>
            </div>
        </div>
    </div>
      <!-- <button id="myMap" ng-click="callMap()" class="button button-block customBgColor buttondesign" >{{'CLICKTOVIEW'|translate}}</button> -->
      <div id = "map" style = "width: 100%; height: 100%"></div>
  </ion-content>
  
</ion-view>

<style>
  .navigationDiv{
      padding: 5px 10px;
      position: absolute;
      bottom: 110px !important;
      z-index: 3;
      right: 7% !important;
      border: 2px solid #1a73e8;
      background: #1a73e8;
      color: white;
      font-family: 'Poppins-Regular';
      border-radius: 25px;
  }

  .navigationBtn{
      background: #1a73e8; 
      color: white; 
      border: 1px solid #1a73e8;
  }
  @keyframes spin360 {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.rotate {
  animation: spin360 1s linear infinite;
}

  /* #map{
      top: 5%;
      width: 100%;
      height: 94%;
      position: absolute;
  } */
  /* Ensure the map container takes up full available space */
#map {
    width: 100%;
    height: calc(100% - 80px); /* Leave space for the refresh button */
    position: relative;
}

/* Style for the Refresh Button Container */
.refresh-btn-container {
    padding: 10px;
    position: absolute;
    top: 58rem;
    left: 15rem;
    z-index: 10;
    width: 100%;
    text-align: center;
}


.refresh-btn-container .col {
    display: inline-block;
    vertical-align: middle;
    text-align: center;
}

</style>

<ion-view title="e-Chhattisgarh">

<ion-content ng-controller="SSApplicationCTRL" class="HomeBackground">

	<form name="SSApplication">
    <div class="headingDiv">
      <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="SOCIALSECURITY"><img src="./img/quick-services-32x32.png" width="32" height="32"></h3>
    </div>
		<!--<div class="list">-->

        <label class="input-label padding-left-15 required" translate="SCHEMENAME"></label>
          <select class="select-dropdown" name="SCHEME" ng-model="schemeValue"
                ng-options="obj.value as obj.name for obj in scheme"required>
          <option value="" translate="SELECT">Select</option>
        </select><label class="item item-input item-floating-label" ></label>

        <label class="item item-input item-floating-label">
          <span class="input-label required" translate="NAMEOFAPPLICANT"></span>
          <input type="text" placeholder="{{'NAMEOFAPPLICANT' | translate}}*"  name="nameOfApplicant" ng-model="nameOfApplicant" required/>
          <span class="errorMessage" ng-show="SSApplication.nameOfApplicant.$error.pattern">Please Enter Valid Trust Name</span>
        </label>

        <label class="item item-input item-floating-label">
            <span class="input-label required" translate="AADHARNO"></span>
            <input type="number" placeholder="{{'AADHARNO' | translate}}*" ng-pattern="/^[0-9]{12,12}$/" name="plbAdharNumber" ng-model="AdharNumber" ng-trim="false" ng-pattern="/^[0-9]{12,12}$/" required/>
            <span class="errorMessage" ng-show="SSApplication.plbAdharNumber.$error.pattern" translate="VALIDAADHAR"></span>
        </label>

        <label class="item item-input item-floating-label">
          <span class="input-label required" translate="DATEOFBIRTH" > </span>
          <input type="text"  onfocus="(this.type='date')" onblur="(this.type='text')" ng-change="calculateAge(applicantDate)" placeholder="{{'DATEOFBIRTH' | translate}}*" ng-blur="changeAttr($event)" name="applicantDate" ng-model="applicantDate" ng-trim="false" ng-pattern="^(?:(?:31(\/|-|\.)(?:0?[13578]|1[02]))\1|(?:(?:29|30)(\/|-|\.)(?:0?[1,3-9]|1[0-2])\2))(?:(?:1[6-9]|[2-9]\d)?\d{2})$|^(?:29(\/|-|\.)0?2\3(?:(?:(?:1[6-9]|[2-9]\d)?(?:0[48]|[2468][048]|[13579][26])|(?:(?:16|[2468][048]|[3579][26])00))))$|^(?:0?[1-9]|1\d|2[0-8])(\/|-|\.)(?:(?:0?[1-9])|(?:1[0-2]))\4(?:(?:1[6-9]|[2-9]\d)?\d{2})$" required/>
          <span class="errorMessage" ng-show="SSApplication.applicantDate.$error.pattern">Please Enter Valid Date</span>
        </label>

        <label class="item item-input item-floating-label">
          <span class="input-label required" translate="AGEASON"></span>
          <input type="number" placeholder="{{'AGEASON' | translate}}*"  name="ageAsOnn" ng-model="ageAsOn" ng-trim="false" disabled required/>
          <span class="errorMessage" ng-show="SSApplication.ageAsOnn.$error.pattern">Please Enter Valid  Name</span>
        </label>

        <label class="input-label padding-left-15 required" translate="GENDER"></label>
          <select  class="select-dropdown" name="pdegender" ng-model="pdegender"
                  ng-options="k.value as k.name for k in genoptionsSS" id="appTTlIDg3" required>
            <option value="" translate="SELECT"></option>
          </select>
        <label class="item item-input item-floating-label" ></label>

        <label class="item item-input item-floating-label">
          <span class="input-label required" translate="APPLICANTADDRESS"></span>
          <input type="text" placeholder="{{'APPLICANTADDRESS' | translate}}*"  name="applicAddress" ng-model="applicAddress" required/>
          <span class="errorMessage" ng-show="SSApplication.applicAddress.$error.pattern">Please Enter Valid Address</span>
        </label>

        <label class="item item-input item-floating-label">
          <span class="input-label required" translate="PINCODE"></span>
          <input type="number" placeholder="{{'PINCODE' | translate}}*" ng-pattern="/^[1-9]\d{5,5}$/"  name="pinCode" ng-model="pinCode"  ng-trim="false" required/>
          <span class="errorMessage" ng-show="SSApplication.pinCode.$error.pattern">Please Enter Valid Pincode</span>
        </label>

        <label class="item item-input item-floating-label">
          <span class="input-label required" translate="MOBILENO"></span>
          <input type="number" placeholder="{{'MOBILENO' | translate}}*"  name="mobile" ng-model="mobile" ng-pattern="/^[0-9]{10,10}$/" ng-trim="false" required/>
          <span class="errorMessage" ng-show="SSApplication.mobile.$error.pattern">Please Enter Valid mobile</span>
        </label>

        <label class="input-label padding-left-15" translate="EDUCATION"></label>
        <select  class="select-dropdown" name="education" ng-model="educationValue"
                 ng-options="k.value as k.name for k in education" id="education" >
          <option value="" translate="SELECT"></option>
        </select>
        <label class="item item-input item-floating-label" ></label>

      <label class="input-label padding-left-15 required" translate="MARITALSTATUS"></label>
      <select  class="select-dropdown" name="marital" ng-model="maritalValue"
               ng-options="k.value as k.name for k in marital" id="marital" required>
        <option value="" translate="SELECT"></option>
      </select>
      <label class="item item-input item-floating-label" ></label>

      <label class="input-label padding-left-15 required" translate="CATEGORY"></label>
      <select  class="select-dropdown" name="categorys" ng-model="categoryValue"
               ng-options="k.value as k.name for k in category" id="categorys" required>
        <option value="" translate="SELECT"></option>
      </select>
      <label class="item item-input item-floating-label" ></label>

      <label class="item item-input item-floating-label">
        <span class="input-label" translate="ANUALINCOME"></span>
        <input type="number" placeholder="{{'ANUALINCOME' | translate}}"  name="aIncome" ng-model="aIncome"/>
        <span class="errorMessage" ng-show="SSApplication.aIncome.$error.pattern">Please Enter Valid Income</span>
      </label>

      <label class="input-label padding-left-15 required" translate="TYPEOFDISABILITY"></label>
      <select  class="select-dropdown" name="disability" ng-model="disabilityValue" ng-change="disablitiyValidate()"
               ng-options="k.value as k.name for k in disabiltiy" id="disability" required>
        <option value="" translate="SELECT"></option>
      </select>

    <div ng-if="disableCheck">
      <label class="item item-input item-floating-label" ></label>
      <label class="item item-input item-floating-label">
        <span class="input-label required" translate="PERCENTAGEDISABILITY"></span>
        <input type="number"  placeholder="{{'PERCENTAGEDISABILITY' | translate}}*"  name="pDisability" ng-model="data_.pDisability" required/>
        <span class="errorMessage" ng-show="SSApplication.pDisability.$error.pattern">Please Enter Valid Number</span>
      </label>
    </div>
      <label class="input-label padding-left-15 required" translate="BPL"></label>
        <select  class="select-dropdown" name="bpl" ng-model="bplValue" ng-change="watchBpl()"
                 ng-options="k.value as k.name for k in bpl" id="bpl" required>
          <option value="" translate="SELECT"></option>
        </select>
      <label class="item item-input item-floating-label" ></label>
    <div ng-if="bpl_check">
      <label class="item item-input item-floating-label" >
        <span class="input-label required" translate="BPLINSPECTIONYEAR"></span>
        <input type="number"  placeholder="{{'BPLINSPECTIONYEAR' | translate}}*"  name="InspectionYear" ng-model="data_.bplInspectionYear" required/>
        <span class="errorMessage" ng-show="SSApplication.bplInspectionYear.$error.pattern">Please Enter Valid Inspection Year</span>
      </label>
      <label class="item item-input item-floating-label">
        <span class="input-label required" translate="BPLFAMILYID"></span>
        <input type="number"  placeholder="{{'BPLFAMILYID' | translate}}*"  name="bplFamilyId" ng-model="data_.bplFamilyId" ng-pattern="/^[0-9]{6,6}$/" ng-trim="false" required/>
        <span class="errorMessage" ng-show="SSApplication.bplFamilyId.$error.pattern">Please Enter Valid BPL id</span>
      </label>
    </div>
      <label class="item item-input item-floating-label">
        <span class="input-label required" translate="LASTDATEOFLIFECERTIFICATE"></span>
        <input type="text"  onfocus="(this.type='date')" onblur="(this.type='text')" placeholder="{{'LASTDATEOFLIFECERTIFICATE' | translate}}*"  name="lastDateOf" ng-model="lastDateOf" required/>
        <span class="errorMessage" ng-show="SSApplication.lastDateOf.$error.pattern">Please Enter Last Date of Certificate</span>
      </label>
    <div class="headingDiv">
      <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="BANKDETAILS"><img src="./img/quick-services-32x32.png" width="32" height="32"></h3>
    </div>

    <label class="input-label padding-left-15 required" translate="BANKNAME"></label>
    <select  class="select-dropdown" name="bankname" ng-model="bankNameValue"
             ng-options="k.value as k.name for k in bank" id="bankName" required>
      <option value="" translate="SELECT"></option>
    </select>
    <label class="item item-input item-floating-label" ></label>

    <label class="item item-input item-floating-label">
      <span class="input-label required" translate="ACCOUNTNO"></span>
      <input type="number" placeholder="{{'ACCOUNTNO' | translate}}*"  name="accountNo" ng-model="accountNo" ng-pattern="/^[0-9]{12,12}$/" ng-trim="false" required/>
      <span class="errorMessage" ng-show="SSApplication.accountNo.$error.pattern">Please Enter Valid Account no</span>
    </label>

    <div class="headingDiv">
      <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="APPLICATIONFAMILY"><img src="./img/quick-services-32x32.png" width="32" height="32"></h3>
    </div>

    <label class="item item-input item-floating-label">
      <span class="input-label required" translate="NAMEOFFATHERSPOUSE"></span>
      <input type="text" placeholder="{{'NAMEOFFATHERSPOUSE' | translate}}*"  name="nameOfFatherSpouse" ng-model="nameOfFatherSpouse" required/>
      <span class="errorMessage" ng-show="SSApplication.nameOfFatherSpouse.$error.pattern">Please Enter Name Of father or spouse</span>
    </label>

    <label class="item item-input item-floating-label">
      <span class="input-label required" translate="NAMEOFMOTHER"></span>
      <input type="text" placeholder="{{'NAMEOFMOTHER' | translate}}*"  name="nameOfMother" ng-model="nameOfMother" required/>
      <span class="errorMessage" ng-show="SSApplication.nameOfMother.$error.pattern">Please Enter Name Of Mother</span>
    </label>

    <label class="item item-input item-floating-label">
      <span class="input-label required" translate="CONTACTNO"></span>
      <input type="number" placeholder="{{'CONTACTNO' | translate}}*"  name="contactNo" ng-model="contactNo" ng-pattern="/^[0-9]{10,10}$/" ng-trim="false" required/>
      <span class="errorMessage" ng-show="SSApplication.contactNo.$error.pattern">Please Enter Contact No.</span>
    </label>

    <label class="item item-input item-floating-label">
      <span class="input-label required" translate="DETAILFAMILYINCOMSOURCE"></span>
      <input type="text" placeholder="{{'DETAILFAMILYINCOMSOURCE' | translate}}*"  name="familyIncomeSource" ng-model="familyIncomeSource" required/>
      <span class="errorMessage" ng-show="SSApplication.familyIncomeSource.$error.pattern">Please Enter Family Income Source</span>
    </label>

    <label class="item item-input item-floating-label">
      <span class="input-label" translate="ANUALINCOMEOFFAMILY"></span>
      <input type="number" placeholder="{{'ANUALINCOMEOFFAMILY' | translate}}"  name="familyIncome" ng-model="familyIncome" />
      <span class="errorMessage" ng-show="SSApplication.familyIncome.$error.pattern">Please Enter Family Income </span>
    </label>

    <div class="padding">
    <button ng-disabled="!SSApplication.$valid" ng-click="submitApplication()" class="button button-block  customBgColor">
    <span translate="Proceed"></span></button>
    </div>
</form>

 </ion-content>
</ion-view>
<style>
.item-expand {
position: relative;
width: 100%;
max-height: 60px;
transition: max-height 0.1s ease-out;
overflow: hidden;
}

.item-expand.inactive:after {
content: "";
position: absolute;
bottom: 0px;
left: 0;
height: 2px;
width: 100%;
display: block;
background-image: -webkit-gradient(
linear,
left top,
left bottom,
color-stop(0, rgba(255, 255, 255, 0)),
color-stop(1, rgba(255, 255, 255, 1))
);
background-image: -o-linear-gradient(bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 1) 100%);
background-image: -moz-linear-gradient(bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 1) 100%);
background-image: -webkit-linear-gradient(left, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 1) 100%);
background-image: -ms-linear-gradient(bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 1) 100%);
background-image: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 1) 100%);
}

.item-expand.active {
max-height: 200px;
transition: max-height 0.3s ease-out;
}


/* DEMO */
.expand-item {
color: red;
margin-top: 10px;
}

.expand-item i {
margin-right: 10px;
}

</style>

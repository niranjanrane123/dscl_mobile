						<option value="LOCATION" ng-disabled="locationdisabled" >{{ 'LOCATION' | translate}}</option>
						<option value="EMPLOYEE">{{ 'EMPWDEPT' | translate}}</option>
					</select>

      <div id="Locdiv" ng-if="data.empdepttmode == 'LOCATION'">

        <div ng-repeat = "data in compList">
          <label  class="input-label padding-left-15 required"> {{ data.name }} </label>
          <select class="select-dropdown" id ="{{ 'level-' + data.index }}" ng-model="data.locItem"
             ng-click="retriveId($event)"
             ng-change="changefunction(data.locItem)" >
            <option value=""> Select </option>
          </select>
        </div>
      </div>


					<div ng-if="data.empdepttmode == 'EMPLOYEE'">
						<label class="input-label padding-left-15 required" translate="EMPNAME"> </label>
						<select class="select-dropdown" name="data.empID" ng-model="data.empID"
						ng-options="o.empid as o.empname for o in employeeoptions" required>

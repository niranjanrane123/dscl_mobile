       <!-- <label class="input-label padding-left-15 required" translate="ACTAPPL"></label>
        <select class="select-dropdown" name="actionappln" ng-model="actionappln"  required>
          <option value="">Select</option>
          <option value="SEND_FOR_FEEDBACK">Request for Citizen Feedback</option>
          <option value="REJECTED">Marked Unsolvable</option>
          <option value="APPROVED" ng-if="deptResolved">Resolved</option>
        </select>-->

		<label class="input-label padding-left-15 required" translate="ACTAPPL"></label>
		<select class="select-dropdown" name="actionappln"
				ng-model="actionappln" ng-options="o.value as o.name for o in action"  required>
			<option value="">Select</option>
		</select>

				<label class="item item-input item-floating-label"></label>
			  <label class="item item-input item-floating-label">
          <input type="file" placeholder="Attach File" name="CompDocument" ng-model="CompDocument" id="verfiyFile"
          ng-trim="false" onchange="angular.element(this).scope().imageupload()" ng-pattern="/^([a-zA-Z]+\s)*[a-zA-Z]+$/" />
          <span class="errorMessage" ng-show="departmentfilledform.CompDocument.$error.pattern">Please Select Valid File</span>
			  </label>

		 <label class="item item-input item-floating-label">
          <span class="input-label required" translate="REMARKS"></span>
          <input type="text" placeholder="{{ 'REMARKS' | translate}}*" name="remarks" ng-model="remarks" ng-trim="false"
           ng-pattern="/^([a-zA-Z]+\s)*[a-zA-Z]+$/" required/>
          <span class="errorMessage" ng-show="departmentfilledform.remarks.$error.pattern">Please Enter Valid Remarks</span>
			 </label>
		</div>

	<div class="padding">
		<button ng-disabled="!departmentfilledform.$valid" ng-click="savedeptAction()" class="button button-block  customBgColor">
		<span translate="">Submit</span></button>
	</div>

</form>

</ion-content>
</ion-view>

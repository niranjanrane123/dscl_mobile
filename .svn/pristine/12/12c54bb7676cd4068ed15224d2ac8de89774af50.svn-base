<ion-view title="{{'ECHATTISGARH' | translate}}">
  <ion-nav-bar class="bar-dark" align-title="center">    <ion-nav-back-button></ion-nav-back-button></ion-nav-bar>

<ion-content ng-controller="ComplaintCareCtrl" class="HomeBackground">
  <div class="headingDiv">
    <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="COMPLDETS">
      <img src="../www/img/quick-services-32x32.png" width="32" height="32"></h3>
  </div>
	 <table class="gridtable">
		 <tr>
			<th translate="TOKENNUMBER">Token Number</th>
			<td>{{ tokennumber }}</td>
		 </tr>
		 <tr>
			<th translate="DEPARTMENT"></th>
			<td>{{ Deptdetails }}</td>
		 </tr>
		 <tr>
			<th translate="COMPLTYPE"></th>
			<td>{{ CompTypedetails }}</td>
		 </tr>
		 <tr>
			<th translate="COMPLDESC"> </th>
			<td>{{ CompDescriptiondetails }}</td>
		 </tr>
		 <tr>
			<th translate="PINCODE"></th>
			<td>{{ CompPincodedetails }}</td>
		 </tr>
		 <tr>
			 <th translate="AGEOFREQUEST"> </th>
			 <td>{{ Compaggetails }}</td>
		 </tr>
		 <tr>
			<th translate="MODE"> </th>
			<td>{{ CompModedetails }}</td>
		 </tr>
		 <tr>
			 <th translate="CATEGORY"> </th>
			 <td>{{ CompCategorydetails }}</td>
		 </tr>
		 <tr >
			 <th translate="WARDKARALAYA"> </th>
			 <td>{{ CompWarddetails }}</td>
		 </tr>
		 <tr ng-if="CompWarddetails2">
			 <th translate="WARD"> </th>
			 <td>{{ CompWarddetails2 }}</td>
		 </tr>
		 <tr ng-if="CompWarddetails3">
			 <th translate="WARD"> </th>
			 <td>{{ CompWarddetails3 }}</td>
		 </tr>
		 <tr ng-if="CompWarddetails4">
			 <th translate="WARD"> </th>
			 <td>{{ CompWarddetails4 }}</td>
		 </tr>
		 <tr ng-if="CompWarddetails5">
			 <th translate="WARD"> </th>
			 <td>{{ CompWarddetail5 }}</td>
		 </tr>
<!--		 <tr>-->
<!--			 <th translate="WARD"> </th>-->
<!--			 <td>{{ CompLocationdetails }}</td>-->
<!--		 </tr>-->
		 <tr>
			 <th translate="REFERENCEDATE"> </th>
			 <td>{{ CompReferenceDatedetails }}</td>
		 </tr>
		 <tr>
			 <th translate="SEL_TYPE_APPL"> </th>
			 <td>{{ CompTypeAppldetails }}</td>
		 </tr>
		 <tr>
			 <th translate="NAME"> </th>
			 <td>{{ CompNamedetails }}</td>
		 </tr>
		 <tr>
			 <th translate="GENDER"> </th>
			 <td>{{ CompGenderdetails }}</td>
		 </tr>
		 <tr>
			 <th translate="MOBILENO"> </th>
			 <td>{{ CompNodetails }}</td>
		 </tr>
		 <tr>
			 <th translate="EMAILADDRESS"> </th>
			 <td>{{ CompEmaildetails }}</td>
		 </tr>
		 <tr>
			 <th translate="ADDRESS"> </th>
			 <td>{{ Compadddetails }}</td>
		 </tr>

	</table>

<form name="departmentfilledform" >
	<div class="list">
    <button class="rightcss customButtonSmall" ng-click="actionhistory()">Action History</button><br>
    <div class="headingDiv" style="margin:3% 1% !important;">
      <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="DEPTACT">Action History</h3>
    </div>

<!--
for product purpose
			  <label class="input-label padding-left-15 required" translate="ACTAPPL"></label>
				<select class="select-dropdown" name="actionappln" ng-model="actionappln" ng-change="Actionselected()"  required>
					<option value="">Select</option>
					<option value="APPROVED">{{ 'CLOSED' | translate}}</option>
					<option value="HOLD">{{ 'ONHOLD' | translate}}</option>
					<option value="REJECTED">{{ 'REJECT' | translate}}</option>
					<option value="FORWARD_TO_DEPARTMENT">{{ 'REVDEPT' | translate}}</option>
					<option value="FORWARD_TO_EMPLOYEE">{{ 'EMPDEPT' | translate}}</option>
				</select>


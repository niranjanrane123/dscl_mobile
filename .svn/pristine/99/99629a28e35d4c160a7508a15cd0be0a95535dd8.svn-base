<ion-view class="titlecss" ng-controller="AtoBRouteDetailsCtrl">
  <ion-nav-bar class="bar-dark" align-title="center">
    <ion-nav-back-button class="button-clear">
      <button class="icon ion-chevron-left" ng-click="myGoBack()" style="background: transparent;border: none;"></button>
      <img style="right: 46%; position: absolute; margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width="38px" height="35px">
    </ion-nav-back-button>
  </ion-nav-bar>

  <div style="margin-top: 25% !important;">
    <div class="headingDiv">
      <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading">{{heading}}</h3>
    </div>
  </div>

  <ion-content class="has-so-subheader" delegate-handle="so-handle" has-bouncing="false" style="margin-top: 10%;">
    <ion-list class="fsa-list so-list">

      <ion-item class="bus-card item-text-wrap card so-item" ng-repeat="job in restripPlannerList track by $index">
        <div class="bus-card-content" style="margin-bottom: 3rem;" ng-click="onLiveMapClick(job);">

          <!-- Header Row -->
          <div class="bus-card-header">
            <div class="route-main">
              <span class="route-name">{{job.routeName}}</span>
              <span class="route-via"> - {{job.routeViaName}}</span>
            </div>
            <div class="trip-time">
              {{job.tripTime | date:'shortTime'}}
            </div>
          </div>

          <!-- Source to Destination -->
          <div class="row bus-info-row">
            <div class="col icon-text">
              <i class="icon ion-android-bus bus-icon"></i>
              <span><strong>{{ 'SOURCE' | translate }}:</strong> {{job.source}}</span>
            </div>
            <div class="col icon-text">
              <i class="icon ion-flag bus-icon"></i>
              <span><strong>{{ 'DESTINATION' | translate }}:</strong> {{job.destination}}</span>
            </div>
          </div>

          <!-- Fleet and Next Stop -->
          <div class="row bus-info-row">
            <div class="col icon-text">
              <i class="icon ion-model-s bus-icon"></i>
              <span><strong>{{ 'BUSNUMB' | translate }}:</strong> {{job.fleetNo}}</span>
            </div>
            <div class="col icon-text">
              <i class="icon ion-location bus-icon"></i>
              <span><strong>{{ 'NEXTSTOP' | translate }}:</strong> {{job.nextStop}}</span>
            </div>
          </div>

          <!-- ETA -->
          <div class="row bus-info-row" ng-if="job.nextStopETA">
            <div class="col icon-text">
              <i class="icon ion-clock bus-icon"></i>
              <span><strong>{{ 'ETA' | translate }}:</strong> {{job.nextStopETA}}</span>
            </div>
          </div>

          <!-- Main Action Button -->
          <!-- <div class="row bus-card-actions">
            <button ng-click="onLiveMapClick(job, showButtons)" class="liveBusClass routeNameCSS customBgColor">
              {{'DETAILS' | translate}} <i class="icon ion-arrow-down-b"></i>
            </button>
          </div> -->

          <!-- Expanded Action Buttons -->
          <div style="margin-top: 1rem;" class="row bus-card-actions-expanded">
            <button class="liveBusClass customBgColor" ng-click="showTimeTable(job)">
              {{'SHOWTIMETABLE' | translate}}
            </button>
            <!-- <button class="liveBusClass routeNameCSS customBgColor" ng-click="goToMap()" ng-if="showMapBtn">
              {{'SHOWLIVESTATUS' | translate}}
            </button> -->
          </div>

        </div>
      </ion-item>

    </ion-list>
  </ion-content>
</ion-view>

<style>
  /* === Custom Bus Card Styles === */
  .bus-card {
    background: #fff;
    border-radius: 12px;
    padding: 12px;
    margin: 10px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
  }

  .bus-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: nowrap;
    margin-bottom: 8px;
  }

  .route-main {
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 70%;
  }

  .route-name {
    font-weight: 600;
    font-size: 16px;
    color: #333;
  }

  .route-via {
    font-size: 14px;
    color: #666;
    margin-left: 4px;
  }

  .trip-time {
    font-size: 14px;
    color: #007bff;
    font-weight: 500;
    white-space: nowrap;
  }

  .bus-info-row {
    margin: -20px 0;
    display: flex;
    flex-wrap: wrap;
  }

  .icon-text {
    display: flex;
    align-items: center;
    flex: 1 1 100%;
    font-size: 14px;
    color: #444;
    margin: -3px 0;
  }

  .bus-icon {
    font-size: 16px;
    margin-right: 6px;
    color: #007bff;
  }

  /* .bus-card-actions {
    margin-top: 10px;
  } */

  .bus-card-actions-expanded {
    margin-top: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  /* .liveBusClass {
    padding: 7px 14px;
    font-size: 13px;
    border-radius: 6px;
    background-color: #007bff;
    color: #fff;
    border: none;
  } */

  .liveBusClass:hover {
    background-color: #0056b3;
  }

  .customBgColor {
    background-color: #28a745 !important;
  }
  .row + .row {
  margin-top: -10px;
  padding-top: 0;
}

/* Add margin below the DETAILS button */
.bus-card-actions {
  margin-top: 12px;
  margin-bottom: 14px; /* ensures button isn't cut off */
}

.liveBusClass {
  padding: 7px 14px;
  font-size: 13px;
  border-radius: 6px;
  background-color: #007bff;
  color: #fff;
  border: none;
  display: inline-block;
}

/* Optional: make the DETAILS button more visible */
.liveBusClass i {
  margin-left: 6px;
}


  @media (max-width: 600px) {
    .bus-card {
      padding: 10px;
    }

    .route-name {
      font-size: 15px;
    }

    .route-via {
      font-size: 13px;
    }

    .trip-time {
      font-size: 13px;
    }

    .icon-text {
      font-size: 13px;
    }

    .liveBusClass {
      font-size: 12px;
      padding: 6px 10px;
    }
  }
</style>

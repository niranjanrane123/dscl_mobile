       $scope.departmentType = function(value) {
        $scope.department = value
          RestService.getDepartmentLocByOrg($localStorage.applicantDetails.org,19)
            .then(function(response){
              console.log("department loc"+JSON.stringify(response));
              if(response.length > 0){
                  var listResponse = response;
                  $scope.departmentLoc = new Array();
                  for(var i=0;i<listResponse.length;i++){
                    if(listResponse[i].descLangFirst == "Head Office"){
                    $scope.location = listResponse[i].descLangFirst
                  if($localStorage.langNewId == "2"){
                  $scope.departmentLoc.push({
                      value : listResponse[i].lookUpId,
                      name : listResponse[i].descLangSecond
                    })
                  }else{
                        $scope.departmentLoc.push({
                          value : listResponse[i].lookUpId,
                          name : listResponse[i].descLangFirst
                        })
                    }
                    $scope.location = 1
                    console.log('hello', $scope.departmentLoc);
                  }
                  }
                  console.log("preparationLoc"+JSON.stringify($scope.departmentLoc))
                $ionicLoading.hide();
              }
              else {
                $ionicLoading.hide();
                toaster.error($filter('translate')('ERROR'), $filter('translate')('ERROR_OCCURED'));

              }
            },function(err){
              toaster.error($filter('translate')('ERROR'), $filter('translate')('ERROR_OCCURED'));
              $ionicLoading.hide();
            })
        }
  $scope.paymentmode = function(payModeID)
  {
    console.log("payModeID---"+payModeID);
    console.log("bankList---"+JSON.stringify($sessionStorage.response));
      for(var i=0;i<$sessionStorage.response.PAY.length;i++){
        if($sessionStorage.response.PAY[i].lookUpId == payModeID){
              $scope.payModeCode = $sessionStorage.response.PAY[i].lookUpCode;
               console.log("$scope.payModeCode---"+$scope.payModeCode);
              if($scope.payModeCode == "C")
              {
                $scope.collectionModeDetails = false;
              }else{
                $scope.collectionModeDetails = true;
              }
          }
      }
  }

        			for(var k=0;k<$scope.subjects2.length;k++)
        			{
        				var documentObject =
        				{
        					attachmentId: $scope.subjects2[k].attachmentId,
        					documentId: $scope.subjects2[k].documentId,
        					documentName: $scope.fileName,
        					documentSerialNo: $scope.subjects2[k].documentSerialNo,
        					descriptionType: $scope.subjects2[k].descriptionType,
        					documentType: $scope.subjects2[k].documentType,

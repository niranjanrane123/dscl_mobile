        					doc_DESC_ENGL: $scope.subjects2[k].doc_DESC_ENGL,
        					documentByteCode: null,
        					checkkMANDATORY: $scope.subjects2[k].checkkMANDATORY
        				};

        				if($localStorage.Lock== 0)
        				{
        					if($scope.subjects2[k].documentId == idValue1)
        					{
        						documentObject.documentName		=	verfy.name;
        						documentObject.documentByteCode	=	$scope.encoded_file1;
        					}
        					arrayListTest.push(documentObject);
        					if((k+1)==$scope.subjects2.length)
        					{
        						$localStorage.Lock = 1;
        					}
        				}
        				else
        				{
        					for (var l=0; l <arrayListTest.length; l++) {
                                if (arrayListTest[l].documentId == idValue1 && $scope.subjects2[k].documentId == idValue1)
                                {
                                  arrayListTest[l].documentName		    =	$scope.fileName;
                                  arrayListTest[l].documentSerialNo 	= 	$scope.subjects2[k].documentSerialNo;
                                  arrayListTest[l].doc_DESC_Mar 		=	$scope.subjects2[k].doc_DESC_Mar;
                                  arrayListTest[l].doc_DESC_ENGL 		=	$scope.subjects2[k].doc_DESC_ENGL;
                                  arrayListTest[l].documentByteCode	    =	    $scope.encoded_file1;
                                  arrayListTest[l].checkkMANDATORY 	= 	$scope.subjects2[k].checkkMANDATORY;
                                }
        				   }
        				}
        			}
        			console.log("Final $localStorage.TempArray-----"+JSON.stringify(arrayListTest));
        		};
        		reader.readAsBinaryString(verfy);
        		}else{
        	  	  arrayListTest = [];
        		  $localStorage.Lock = 0;
        		}
        	};

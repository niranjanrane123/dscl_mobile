        $scope.savePaymentRequest=function(data)
        {
          
        var params={
            "serviceId": data.serviceId,
            "applicationId":data.apmApplicationId,
            "applicantName": data.fName+' '+data.lName,
            "dueAmt": data.amountToPay,
            "mobNo": data.mobileNo,
            "email":data.email,
            "serviceName": "File RTI On-line",
            "udf1": data.serviceId,
            "udf2": data.apmApplicationId,
            "udf3": "CitizenHome.html",
            "udf4": null,
            "udf5": data.serviceShortCode,
            "udf6": null,
            "udf7": "null",
            "udf8": null,
            "udf9": null,
            "udf10": data.deptId,
            "errors": null,
            "finalAmount": btoa(data.amountToPay),
            "validateAmount": data.amountToPay,
            "key": null,
            "txnid": data.txnid,
            "salt": null,
            "bankId": null,
            "hash": null,
            "controlUrl": RestService.cxfServiceUrl+"rest/commonPaymentController/savePaymentRequest",
            "pgUrl": null,
            "successUrl": RestService.eipURL+"/RtiApplicationUserDetailForm.html?payuSuccess",
            "failUrl": RestService.eipURL+"/RtiApplicationUserDetailForm.html?failPayU",
            "cancelUrl": RestService.eipURL+"/RtiApplicationUserDetailForm.html?cancelPayU",
            "errorCause": null,
            "onlineBankList": null,
            "orgId": data.orgId,
            "empId": data.empId,
            "payRequestMsg": null,
            "pgName": null,
            "merchantId": null,

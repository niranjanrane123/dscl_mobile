<ion-view title="{{'ITS' | translate}}" class="titlecss">
    <ion-content delegate-handle="so-handle" has-bouncing="false">
        <ion-list class="fsa-list so-list">
            <ion-item class="item-text-wrap card so-item" ng-repeat="job in respcompainList track by $index">
                <div class="row">
                    <div class="col padding">
                        <h2 class="text-left">{{job.Source}}</h3>
                    </div>
                </div>
            </ion-item>
        </ion-list>

    </ion-content>
</ion-view>
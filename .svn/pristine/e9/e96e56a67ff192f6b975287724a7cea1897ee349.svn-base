<ion-view class="titlecss" >
  <!-- title="{{'ECHATTISGARH' | translate}}" -->
  <ion-nav-bar class="bar-dark" align-title="center">
		<ion-nav-back-button class="button-clear">
		  <button class="icon ion-chevron-left" ng-click="myGoBack()" ng-controller="TodoCtrl"  style="background: transparent;border: none;"></button>
		  <img style="right: 46%;
		  position: absolute;
		  margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width=38px; height=35px;>
		</ion-nav-back-button>
	  </ion-nav-bar>
<ion-content ng-controller="complaintreceiptctrl" class="HomeBackground">

<!--  <div style="padding-left :10px;padding-right :10px;">-->
<!--    <button ng-click="takeScreenShot()" class="button button-block  customBgColor">-->
<!--      <span translate="SHARE"></span></button>-->
<!--  </div>-->
<form name="complaintreceipt">
<div class="list">
      <div style = "background-color: 00aa55;"class="headingDiv">
        <b class="alignleft" translate="COMPLRECIDETS"></b>
        <img src="./../www/img/share-flat.png" ng-click="takeScreenShot()" width=35px; height=35px;>

        <!--        <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="COMPLRECIDETS">-->
<!--         <img  src="../../www/img/share-flat.jpg" width=30px; height=30px;>-->
<!--        </h3>-->
      </div>
    <div id="target" style="background-color: #ffffff;">
      <table class="gridtable">
        <tr ng-if="ReceiptToken">
          <th style="width: 50%;" translate="COMPLAINTNO"></th>
          <td>{{ ReceiptToken }}</td>
        </tr>
        <tr ng-if="date">
          <th style="width: 50%;" translate="COMPLAINTDATE"></th>
          <td>{{ date }}</td>
        </tr>
        <tr ng-if="ReceiptapplName">
          <th style="width: 50%;" translate="APPLICANTNAME"></th>
          <td>{{ ReceiptapplName }}</td>
        </tr>
        <tr ng-if="ReceiptCompdept">
          <th style="width: 50%;" translate="DEPARTMENT"></th>
          <td >{{ ReceiptCompdept }}</td>
        </tr>
        <tr ng-if="CompltypeReceipt">
          <th translate="COMPLTYPE"></th>
          <td >{{ CompltypeReceipt }}</td>
        </tr>
        <tr ng-if="LocationReceipt">
          <th style="width: 50%;" translate="LOCATION"></th>
          <td>{{ LocationReceipt  }}</td>
        </tr>
        <tr ng-if="ReceiptDescrition">
          <th style="width: 50%; word-wrap:break-word;" translate="DESCRIPTION"></th>
          <td>{{ ReceiptDescrition  }}</td>
        </tr>
      </table>
    </div>
    <div style="background-color: #ffffff; height: 45%;">
      <div ng-if="esctable">
        <div class="headingDiv" style="padding: 0px 0px 0px 0px !important;">
           <h3 style="height:32px;" class="heading" translate="COMPLESCDETS"></h3>
        </div>
        <table class="gridtable" ng-repeat="subject in escalDetailsList">
        <tr ng-if="subject.level">
          <th width="50%" translate="LEVEL"></th>
          <td>{{ subject.level }}</td>
        </tr>
        <tr ng-if="subject.duration">
          <th width="50%" translate="DURATION"></th>
          <td>{{ subject.duration }}</td>
        </tr>
        <tr ng-if="subject.empName">
          <th width="50%" translate="EMPNAME"> </th>
          <td>{{ subject.empName }}</td>
        </tr>
        <tr ng-if="subject.designation">
          <th width="50%" translate="DESIGNATION"> </th>
          <td>{{ subject.designation }}</td>
        </tr>
        <tr ng-if="subject.department">
          <th width="50%" translate="DEPARTMENT"></th>
          <td>{{ subject.department }}</td>
        </tr>
        <tr ng-if="subject.email">
          <th width="50%" translate="EMAIL"></th>
          <td >{{ subject.email }}</td>
        </tr>
      </table>

    </div>
   </div>
  <div style="padding :10px;">
    <button ng-click="homepage()" class="button button-block  customBgColor">
      <span translate="HOMEPAGE"></span></button>
  </div>
</div>

</form>
</ion-content>
</ion-view>
<style>
.gridtable12{
width:96%!important;
margin:0% 2% 2% 2%;
font-size: 14px;
color: #333333;
border-collapse: collapse;
overflow-x: auto;
text-align: center;
}

.gridtable12 th {
font-size:14px;
padding:5px 10px;
background-color: rgba(255, 255, 255, 0.5);
border:1px solid rgba(81, 81, 81, 0.4);
text-align: left;
vertical-align: top;
width: 50%;
}

.gridtable12 td {
font-size: 14px;
padding: 5px 0 5px 10px;
background-color: rgba(255, 255, 255, 0.5);
border: 1px solid rgba(81, 81, 81, 0.4);
text-align: left;
vertical-align: middle;
}
.stickyFooter {
  padding: 20px;
  width: 100%;
  bottom: -60px;
  position: absolute;
  }

.gridtable12 th img{
align: center !important;
}
.headingDiv{
font-size:1.12em;padding: 5px 0px 0px 10px; line-height:20px; height:32px;font-family:'Open Sans'; font-weight:500; background:#00aa55;color:#fff; border-radius: 6px 6px 0px 0px;
}
.gridtable12 td img{
align: center !important;
}
.alignleft {
	float: left;
    width: 88%;
    padding: 2px;
    margin-left: 5px;

}
.alignright {
	float: right;
}
.hideextra { white-space: nowrap; overflow: hidden; text-overflow:ellipsis; }
</style>

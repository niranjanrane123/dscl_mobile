      <!-- Quick Services End -->

      <!-- Important, Public, Quick Links Start -->

          <div class="row margin-0" style="background-color: #d5f3e3;">
              <div class="col col-33" ng-click="openLink('Quick')">
                <div class="list list-icon text-center">
                 <p style="font-size:12px;padding-left: 5px;font-weight: 600;" translate="QUICK_LINKS" >Quick Links</p>
                  <a class=" gridnopadding">   
                    <img src="img/linkearth.png" height="30" width="30">


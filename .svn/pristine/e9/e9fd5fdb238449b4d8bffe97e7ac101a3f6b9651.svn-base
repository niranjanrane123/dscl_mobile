<ion-view   hide-back-button="true">
  <ion-nav-view name=“menuContent” animation=“slide-left-right”></ion-nav-view>
  <ion-nav-buttons side="left">
    <button class="button button-icon button-clear ion-navicon" menu-toggle="left"></button>
    <!-- <div side="center">
      <img src="./img/doon1-3d-test_13-10-2021.png" style="margin-left: 153px;
      width: 45px;">
      </div> -->
      <img style="right: 46%;
   position: absolute;
   margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width=38px; height=35px;>
    <!-- <img style="left: 197px; position: absolute; margin-top: 1px;" src="./img/Dehradun_Logo.jpg" width=30px; height=30px;> -->
</ion-nav-buttons>
  <ion-nav-buttons side="right">
      <button class="login-button" ng-controller="LandingPageCtrl" ng-click="openLogin()" translate="LOGIN1">Login</button>
      <!-- <button class="languagebuttton"  align="center">English</button> -->
      <!-- <button class="languagebuttton" ng-controller="LandingPageCtrl" ng-click="changeText(myText)" align="center">{{ myText }}</button> -->
    </ion-nav-buttons>
   
    <ion-content ng-controller="LandingPageCtrl" >

     
      <!-- Slider Start -->
        <ng-include src="'templates/LandingPage/LandingSlider.html'"></ng-include>
        <!-- Slider end -->

      <!-- On Going Projects Start-->

     <div id="on-going" style="background-color: #effff7;">
          <div class="head-link">
              <h2>{{ 'ON_GOING_PROJECTS' | translate}}</h2>
              <p><a ng-click="viewAll()" >{{'VIEW_MORE' | translate}}</a></p>
          </div>
         
          <div class="row margin-0">
              <div class="col col-33">
                <div class="list list-icon text-center">
                  <a class=" gridnopadding">
                    <!-- ui-sref="app.complaintrefrence" -->
 
                    <img src="img/ongoing-project1.jpg">
                  </a>
                  <h5 style="font-size:12px;padding-left: 5px;">{{'WATER_SUPPLY' | translate}}</h5>
                </div>
               
              </div>

              <div class="col col-33">
                  <div class="list list-icon text-center">
                    <a class=" gridnopadding">
                      <!-- ui-sref="app.complaintrefrence" -->
   
                      <img src="img/ongoing-project2.jpg">
                    </a>
                    <h5 style="font-size:12px;padding-left: 5px; ">{{'SMART_SCHOOL' | translate}}</h5>
                  </div>
                 
                </div>

                <div class="col col-33">
                  <div class="list list-icon text-center">
                    <a class=" gridnopadding">
                      <!-- ui-sref="app.complaintrefrence" -->
   
                      <img src="img/ongoing-project3.png">
                    </a>
                    <h5 style="font-size:12px;padding-left: 5px; ">{{'SMART_TOILET' | translate}}</h5>
                  </div>
               
                </div>



              </div>

          </div>

       
      <!-- On Going Projects End-->

      <!-- Citizen Services Section Start -->
     <div>
      <div class="head-link" style="background-color:#d5f3e3;">
        <h2 style="margin-bottom: 0.5px;">{{ 'CITIZEN_SERVICES' | translate}}</h2>
    </div>
   
      <div class="row">
        <!-- new complaint form -->
        <div class="col col-33" ng-click="openComplaint()">
          <div class="list list-icon text-center">
            <a class=" gridnopadding">
              <img src="img/fileComplainIcon.png" height="40" width="40">
            </a>
            <h5 style="font-size:12px;padding: 5px;">{{'COMPLAINT_REGISTRATION' | translate}}</h5>
          </div>
        </div>
      
        <!-- new complaint status -->
        <div class="col col-33" ng-click="openComplaintStatus()">
          <div class="list list-icon text-center">
            <a class=" gridnopadding">
              <img src="img/complaintStatusIcon.png" height="40" width="40">
            </a>
            <h5 style="font-size:12px;padding: 5px;">{{'COMPLSTATUS' | translate}}</h5>
          </div>
        </div>
      
        <!-- donation service -->
        <div class="col col-33" ng-click="openDonation()">
          <div class="list list-icon text-center">
            <a class=" gridnopadding">
              <img src="img/donation_icon.png" height="40" width="40">
            </a>
            <h5 style="font-size:12px;padding: 5px;">{{'DONATION_SERVICE' | translate}}</h5>
          </div>
        </div>
      
      </div>
      </div>

      <!--Citizen Services Section End  -->

       <!-- MDDA Start -->

       <div class="head-link" style="background-color:#d5f3e3; margin-bottom: -1px;" >
        <h2 style="margin-bottom: 0.5px;">{{'MDDA' | translate}}</h2>
     </div>
    
     <div class="row margin-0">
      <div class="col col-50" ng-click="mddaProject('appCount')">
        <div class="list list-icon text-center">
          <a class=" gridnopadding">
            <img src="img/mdda-logo.png" height="40" width="40">
          </a>
          <h5 style="font-size:13px;"><span>{{'TOTAL_APP_COUNT' | translate}}<br>{{totalAppCount}}</span></h5>
        </div>
      </div>

      <div class="col col-50" ng-click="mddaProject('bpmsCount')">
        <div class="list list-icon text-center">
          <a class=" gridnopadding" >
            <img src="img/mdda-logo.png" height="40" width="40">
          </a>
          <h5 style="font-size:13px;"><span>{{'TOTAL_BPMS_COUNT' | translate}}<br>{{totalBMPSCount}}</span></h5>
        </div>
      </div>

       </div>
     
      <!-- MDDA End -->

      <!-- Quick Services Start -->

      <!--<div style="border-top: 1px solid #00aa55;">-->
        <div class="head-link" style="background-color:#d5f3e3; margin-bottom: -1px;" >

<style>

.head-link{
padding: 10px;
  display: flex;
  justify-content: space-between;
}

.head-link h2{
color: #555;
font-size: 16px;
font-weight: 600;
}
.head-link p a{
font-size: 12px;
color: #00aa55 !important;
text-decoration: none;
  font-weight: 600;
}

.links p{
  font-size: 12px;
  font-weight: 400;
}



/* Social media css start */


.facebook {

color: white;
}

.twitter {

color: white;
}





.youtube {

color: white;
}

.instagram {

color: white;
}

/* Social media css end */


</style>


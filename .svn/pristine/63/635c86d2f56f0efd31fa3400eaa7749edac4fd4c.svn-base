<ion-view >
  <!-- title="{{'ECHATTISGARH' | translate}}"
  <ion-nav-back-button></ion-nav-back-button> -->
  <ion-nav-bar class="bar-dark" align-title="center">
		<ion-nav-back-button class="button-clear">
		  <button class="icon ion-chevron-left" ng-click="myGoBack()" ng-controller="TodoCtrl"  style="background: transparent;border: none;"></button>
		  <img style="right: 46%;
		  position: absolute;
		  margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width=38px; height=35px;>
		</ion-nav-back-button>
	  </ion-nav-bar>

  <ion-content ng-controller="EnvironmentPageCtrl" class="HomeBackground">
    <!-- <div style="height: 40px;" class="search_categories">
      <div class="select">
        <select id="crimeType" class="item item-input item-select col text-center login crimtype"
          ng-model="complaintReferenceCategory" style="width:100%;"
          ng-options="o.lookUpCode as o.name for o in locationoptions" ng-change="locationpincode()" ng-click="reset()">
          <option value="" translate="LOCATION" required></option>
          <option ng-repeat="crime in locationoptions" value="{{crime.lookUpCode}}">{{crime.lookUpDesc}}</option>
        </select>
      </div>
    </div> -->
    <div class="headingDiv">
      <h3 class="heading" translate="ENVIRONMENT"></h3>
    </div>
    <label class="input-label padding-left-15 required" translate="LOCATION"></label>
    <select class="select-dropdown" name="department" ng-model="complaintReferenceCategory"
    ng-options="o.lookUpCode as o.name for o in locationoptions" ng-change="locationpincode()" ng-click="reset()" required>
      <!-- <option value="" translate="LOCATION"></option> -->
      <option value="" translate="SELECT" disabled></option>
    </select>

    <div>
      <div>
        <div class="row margin-0">
          <div class="table-outer">
            <table class="complaintTable" ng-if="mysearch.length<1 || !mysearch">
              <tr class="table-heading">
                <td translate="INDEXNO">Index No</td>
                <td translate="ITEM_LIST">Item List</td>
                <td translate="DETAILS">DETAILS</td>
              </tr>
              <tr ng-repeat="rowData in devices track by $index">
                <td>{{$index+1}}</td>
                <td>{{devices[$index]}}</td>
                <td>{{tags[$index]}}</td>
              </tr>
            </table>

          </div>
        </div>
      </div>
    </div>
    <!-- 
    <form name="reopenForm">
      <div id="existingcomplaint">
        <div class="card list">
          <div class="item item-text-wrap textcolor">
            <p>NO2: {{ enviornmentData.NO2 }}</p>
            <p>O3: {{ enviornmentData.O3 }}</p>
            <p>PM10: {{ enviornmentData.PM10 }}</p>
            <p>SO2: {{ enviornmentData.SO2 }}</p>
            <p>CO: {{ enviornmentData.CO }}</p>
            <p>CO2: {{ enviornmentData.CO2 }}</p>
            <p>AQI: {{ enviornmentData.AQI }}</p>
            <p>DATE_TIME: {{ enviornmentData.DATE_TIME }}</p>
          </div>
        </div>
      </div>
    </form> -->

  </ion-content>
</ion-view>

<style>
  .dividerbar {
    font-family: 'Open Sans';
    font-weight: 600;
    background-color: #00aa55;
    color: #fff;
  }

  .textcolor {
    font-family: 'Open Sans';
    font-weight: 600;
  }
</style>
<ion-view>
	<!-- title="{{'ECHATTISGARH' | translate}}" -->
	<ion-nav-bar class="bar-dark" align-title="center">
		<ion-nav-back-button class="button-clear">
		  <button class="icon ion-chevron-left" ng-click="myGoBack()" ng-controller="TodoCtrl"  style="background: transparent;border: none;"></button>
		  <img style="right: 46%;
		  position: absolute;
		  margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width=38px; height=35px;>
		</ion-nav-back-button>
		</ion-nav-bar>
<!--   <ion-nav-title>
      <div class="bar bar-header headercolor">
        <h1 class="title">MaiNet</h1>
     </div>
   </ion-nav-title>

<ion-nav-buttons side="left">
        <button class="button button-icon button-clear ion-navicon" menu-toggle="left">
        </button>
 </ion-nav-buttons>-->

<ion-content ng-controller="NewWaterconnAddressCTRL" class="HomeBackground">
<!--<h3 class="heading" translate="ADDRESSDET"> </h3>-->

	<form name="NWCinfoFormAddress" novalidate>
    <div class="headingDiv">
      <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="ADDRESSDET"><img src="./img/quick-services-32x32.png" width="32" height="32"></h3>
    </div>
	 	<div class="list">
			<label class="item item-input item-floating-label">
				<span class="input-label required" translate="ROADNAME"> </span>
				<input type="text" placeholder="{{'ROADNAME' | translate}}*" name="WNCroadname" ng-model="WNCroadname"  required/>
				<span class="errorMessage" ng-show="NWCinfoFormAddress.WNCroadname.$error.pattern" translate="VALIDROADNAME"></span>
			</label>
			<label class="item item-input item-floating-label">
				<span class="input-label required" translate="AREANAME"> </span>
				<input type="text" placeholder="{{'AREANAME' | translate}}*" name="WNCareaname" ng-model="WNCareaname" required/>
				<span class="errorMessage" ng-show="NWCinfoFormAddress.WNCareaname.$error.pattern" translate="VALIDAREANAME"></span>
			</label>
			<label class="item item-input item-floating-label">
				<span class="input-label required" translate="VTCITY"></span>
				<input type="text" placeholder="{{'VTCITY' | translate}}*" name="WNCtowncity" ng-model="WNCtowncity" required/>
				<span class="errorMessage" ng-show="NWCinfoFormAddress.WNCtowncity.$error.pattern" translate="VALIDTOWN"></span>
			</label>
			<label class="item item-input item-floating-label">
				<span class="input-label required" translate="PINCODE"></span>
				<input type="number" placeholder="{{'PINCODE' | translate}}*" name="WNCpincode" ng-model="WNCpincode" ng-trim="false"
				id="addpincode" ng-keyup="onlyNumericSixLimitInput()" ng-pattern="/^[0-9]{6,6}$/" required/>
				<span class="errorMessage" ng-show="NWCinfoFormAddress.WNCpincode.$error.pattern" translate="VALIDPINCODE"></span>
			</label>

			<ion-checkbox name="cb" ng-model="addinfochecked" ng-change="checkedOrNot(addinfochecked)">
			<span class="input-label" translate="CORSP_ADD"></span>	</ion-checkbox>

			<div id="hidebillingdiv" ng-if="billinghide">
				<label class="item item-input item-floating-label">
					<span class="input-label required" translate="ROADNAME"></span>
					<input type="text" placeholder="{{'ROADNAME' | translate}}*" name="data_.WNCbillroadname" ng-model="data_.WNCbillroadname" required/>
					<span class="errorMessage" ng-show="NWCinfoFormAddress.data_.WNCbillroadname.$error.pattern" translate="VALIDROADNAME"></span>
				</label>
				<label class="item item-input item-floating-label">
					<span class="input-label required" translate="AREANAME"> </span>
					<input type="text" placeholder="{{'AREANAME' | translate}}*" name="data_.WNCbillareaname" ng-model="data_.WNCbillareaname" required/>
					<span class="errorMessage" ng-show="NWCinfoFormAddress.data_.WNCbillareaname.$error.pattern" translate="VALIDAREANAME"></span>
				</label>
				<label class="item item-input item-floating-label">
					<span class="input-label required" translate="VTCITY"></span>
					<input type="text" placeholder="{{'VTCITY' | translate}}*" name="data_.WNCbilltowncity" ng-model="data_.WNCbilltowncity" required/>
					<span class="errorMessage" ng-show="NWCinfoFormAddress.data_.WNCbilltowncity.$error.pattern" translate="VALIDTOWN"></span>
				</label>
				<label class="item item-input item-floating-label">
					<span class="input-label required" translate="PINCODE"></span>
					<input type="number" placeholder="{{'PINCODE' | translate}}*" name="data_.WNCbillpincode" ng-model="data_.WNCbillpincode" ng-trim="false"
					id="cncaddpincode" ng-keyup="onlyNumericSixLimitInput()" ng-pattern="/^[1-9]\d{5,5}$/" required/>
					<span class="errorMessage" ng-show="NWCinfoFormAddress.data_.WNCbillpincode.$error.pattern" translate="VALIDPINCODE"></span>
				</label>
			</div>

			 <div class="padding">
        <button ng-disabled="!NWCinfoFormAddress.$valid" ng-click="applicantinfoaddress()" class="button button-block
		      customBgColor">
				<span translate="WATERCONN_NEXT"></span></button>
 			</div>
	</div>
</form>

    </ion-content>
</ion-view>

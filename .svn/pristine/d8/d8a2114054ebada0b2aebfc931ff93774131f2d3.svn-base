<ion-content ng-controller="RtiPayCTRL" class="HomeBackground">
<!--<h3 class="heading" translate="PAYMENT"></h3>-->
<form name="NWCPayForm" >
  <div class="headingDiv">
    <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="PAYMENT"><img src="./img/quick-services-32x32.png" width="32" height="32"></h3>
  </div>

  <div ng-if = "comeFrom =='rti'" class="rti-steps">4 of 4</div>
	<div class="list">
	      <label class="item item-input item-floating-label">
					<span class="input-label" translate="TOTAL_AMOUNT"></span>
					<input type="text" placeholder="{{'TOTAL_AMOUNT' | translate}}" name="FlatRate" ng-model="FlatRate"
					 ng-trim="false" disabled/>
				</label>
      <label class="item item-input item-floating-label">
					<span class="input-label required" translate="APPL_NAME"></span>
					<input type="text" placeholder="{{'APPL_NAME' | translate}}" name="finalAppName" ng-model="loginUSername" required />
					<span class="errorMessage"  ng-show="NWCPayForm.finalAppName.$error.pattern" translate="VALIDAPPLICANT"></span>
				</label>
	             <label class="item item-input item-floating-label">
					<span class="input-label required" translate="MOBILENO"></span>
					<input type="tel" placeholder="{{'MOBILENO' | translate}}" name="finalAppMobile" ng-model="LoginMobileNo"  ng-pattern="/^[0-9]{10,10}$/" required/>
					<span class="errorMessage" ng-show="NWCPayForm.finalAppMobile.$error.pattern" translate="VALIDMOBILE"></span>
				</label>
	            <label class="item item-input item-floating-label">
					<span class="input-label" translate="EMAILID"></span>
					<input type="email" placeholder="{{'EMAILID' | translate}}" name="finalAppEmail" ng-model="emailId" ng-trim="false" ng-pattern="/^([A-Za-z0-9_\-\.])+\@([A-Za-z0-9_\-\.])+\.([A-Za-z]{2,4})$/" />
					<span class="errorMessage" ng-show="NWCPayForm.finalAppEmail.$error.pattern" translate="VALIDEMAIL"></span>
				</label>

        <!-- <label class="input-label padding-left-15 required" translate="PAYGATEWAY"></label>
				<select class="select-dropdown" name="paymentGateway" ng-model="paymentGateway"
					ng-options="o.id as o.name for o in options" required>
					
				</select> -->
				<label class="input-label padding-left-15 required" translate="PAYGATEWAY"></label>
				<select class="select-dropdown" name="paymentGateway" ng-model="paymentGateway" ng-change="Payment(paymentGateway)"
					ng-options="o.id as o.name for o in options" required>
					<option value="" translate="PAYGATEWAY"></option>
				</select>

			
				<div class="padding">
          <!-- <button class="button button-block  customBgColor" ng-click="Payment()" ng-disabled="!NWCPayForm.$valid">
          <span style="color:#fff" translate="PAY"></span></button> -->
	  <button class="button button-block  customBgColor" ng-click="pay()" ng-disabled="!NWCPayForm.$valid">
	  <!-- <button class="button button-block  customBgColor" ng-click="Payment11()" ng-disabled="!NWCPayForm.$valid"> -->
		<span style="color:#fff" translate="PAY"></span></button>
		
			<!-- <button class="button button-block  customBgColor" ng-click="gotoReceipt()" >
				<span style="color:#fff" translate="PAY"></span></button> -->
				</div>
        </div>
	
	
	
		  <!-- <img style="width: 300px; display: block" src="./img/demo-tshirt.svg" /> -->
		  <!-- <button class="button button-positive" ng-click="pay()">
			Pay with Razorpay
		  </button> -->
       </form>

	  
	  

    </ion-content>
 </ion-view>

					<span class="input-label required" translate="SUBJECT"></span>
					<input type="text" placeholder="{{'SUBJECT' | translate}}*" name="firstname" ng-model="subject"
						required />
					<span class="errorMessage" ng-show="contact.subject.$error.pattern" translate="VALIDSUBJECT"></span>
				</label>

				<label class="item item-input item-floating-label">

		<form name="contact">
			<div class="headingDiv">
				<h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="FEEDBACK">
				</h3>
			</div>

			<div class="list">
				<label class="item item-input item-floating-label">
					<span class="input-label required" translate="MOBILENO"></span>
					<input type="number" placeholder="{{'MOBILENO' | translate}}*" name="mobileno" ng-model="mobileno"
						   ng-keyup="onlyNumericTenLimitInput()" ng-trim="false" ng-pattern="/^[0-9]{10,10}$/" required readonly/>
					<span class="errorMessage" ng-show="contact.mobileno.$error.pattern" translate="VALIDMOBILE"></span>
				</label>

				<label class="item item-input item-floating-label">
					<span class="input-label required" translate="FIRSTNAME"></span>
					<input type="text" placeholder="{{'FIRSTNAME' | translate}}*"  name="firstname" ng-model="firstname" required readonly/>
					<span class="errorMessage" ng-show="contact.firstname.$error.pattern" translate="VALIDFIRSTNAME"></span>
				</label>
				<label class="item item-input item-floating-label">
					<span class="input-label required" translate="LASTNAME"></span>
					<input type="text" placeholder="{{'LASTNAME' | translate}}*"  name="lastname" ng-model="lastname"  required readonly/>
					<span class="errorMessage" ng-show="contact.lastname.$error.pattern" translate="VALIDLASTNAME"></span>
				</label>
				<label class="item item-input item-floating-label">
					<span class="input-label required" translate="EMAILID"></span>
					<input type="text" placeholder="{{'EMAILID' | translate}}*" name="EmailD" ng-model="EmailID" ng-trim="false" ng-pattern="/^[A-Za-z0-9/s,.'-@]{1,50}$/" required readonly/>
					<span class="errorMessage" ng-show="contact.EmailD.$error.pattern" translate="VALIDEMAIL"></span>
				</label>
				<label class="item item-input item-stacked-label" style="margin-right: 10px;">
					<span class="input-label required">{{'CONTACDESCRIPYION' | translate}}</span>
					<textarea maxlength='2000' rows="4" placeholder="" name="desc" ng-model="desc" style="border: 1px #bcbcbc solid;padding: 10px; margin-top: 10px;" required></textarea> 
					<div id="char_contact" style="padding: 2px; float: right; font-size: 8px;">{{'MAXIMUM'|translate}} 2000: 2000 {{'LEFT_CHAR'|translate}}</div>
				</label>

				<div class="padding">
					<button ng-click="save()" ng-disabled="!contact.$valid" class="button button-block button-positive customBgColor">
						<span translate="SUBMIT"></span></button>
				</div>
		
			</div>
		</form>
	</ion-content>
</ion-view>


<style>
	.green {
		background-color: #68C39F !important;
		/*#68C39F*/
	}
</style>
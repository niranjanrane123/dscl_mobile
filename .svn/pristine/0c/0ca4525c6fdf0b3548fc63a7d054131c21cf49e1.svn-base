<ion-view class="titlecss" >
  <!-- title="{{'ECHATTISGARH' | translate}}" -->
 
    <ion-nav-buttons side="left" >
      <div class="title title-center header-item" style="font-weight: bold; color: #fff; left: 48px; right: 48px; font-size: 21px; text-align: center; top: 0px;">
        <!-- {{'ECHATTISGARH' | translate}} -->
        </div>
        <img style="right: 46%;
        position: absolute;
        margin-top: 1px;" src="./img/doon1-3d-test_13-10-2021.png" width=38px; height=35px;>	 
	 </ion-nav-buttons>
<ion-content ng-controller="reopenCtrl" class="HomeBackground">

<form name="reopenForm">
<div id="existingcomplaint">
  <div class="headingDiv">
    <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="EXTCOMPLDET"></h3>
  </div>
	<div class="list">
		
		<!-- <input type="text" id="complaintreopensearchinput" ng-pattern="/^[0-9a-zA-Z]{1,20}$/"   alpha-numeric-only ng-trim="false" limit="20" ng-model-options="{ allowInvalid: true}" ng-model="search" class="textcss" placeholder="{{ 'SEARCHBYCOMPNO' | translate }}"> -->
		
    <label class="item item-input item-stacked-label labelClass" style="margin: -2rem 1rem -1rem 1rem !important;">
		  <input type="text" class="inputClass" id="complaintreopensearchinput" ng-pattern="/^[0-9a-zA-Z]{1,20}$/" alpha-numeric-only ng-trim="false" limit="20" ng-model-options="{ allowInvalid: true}" ng-model="search" placeholder="{{ 'SEARCHBYCOMPNO' | translate }}"/>
	  </label>

	</div>

  <div class="headingDiv">
    <h3 style="height:32px;padding: 5px 0px 0px 10px;" class="heading" translate="HISTORY"></h3>
  </div>
	<div class="card list" ng-repeat = "subject in allgrievanceresponse | filter: {complaintId: search}"
	 ng-click="setSelected(subject.complaintId)" >
		  <div class="item item-divider dividerbar">
			<p style="color:#fff;">{{ 'COMPLAINTNO' | translate }}: {{ subject.complaintId }}</p>
			<!-- <i class="icon ion-ios-arrow-right"></i> -->
		  </div>
		<div class="item item-text-wrap">
		  <p><span class = "textcolor">{{ 'STATUS' | translate }}: </span>{{ subject.status | translate }}</p>
		  <p><span class = "textcolor">{{ 'COMPLTYPE' | translate }}: </span>{{ langID=='1'?subject.complaintTypeDesc:subject.complaintTypeDescReg }}</p>
       <p><span class = "textcolor">{{ 'COMPLDESC' | translate }}: </span>{{ subject.description }}</p>
		</div>
	</div>
</div>
</form>

  </ion-content>
</ion-view>

<style>
  .dividerbar
  {
    font-weight:600;
    background-color:#004c8f;
    color:#fff;
   }
  .textcolor{
    font-family:'Open Sans';
    font-weight:600;
  }
</style>
